# Copy this file to .env and fill in your own values
# Never commit your real .env file

# MongoDB connection string
# Local:      mongodb://127.0.0.1:27017/flextenure
# Atlas:      mongodb+srv://<user>:<password>@<cluster>.mongodb.net/flextenure
MONGO_URI=mongodb://127.0.0.1:27017/flextenure

# Secret used to sign JWT auth tokens — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret_string

# How long login tokens stay valid
JWT_EXPIRES_IN=7d

# Port the API server runs on
PORT=5000

# Comma separated list of allowed origins for CORS in production
# e.g. https://flextenure.com,https://www.flextenure.com
CLIENT_ORIGIN=http://localhost:3000
